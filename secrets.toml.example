# Copy this file to:  .streamlit/secrets.toml   (for LOCAL testing only)
# On Streamlit Community Cloud, paste these same values into:
#   App  ->  Settings  ->  Secrets
#
# NEVER commit your real secrets.toml to GitHub (.gitignore already blocks it).

OPENAI_API_KEY = "sk-...your-team-key-here..."
APP_PASSWORD   = "choose-a-shared-team-password"
